# BACKEND/.env.example
# Copy this to .env for local dev, or set these as Vercel Environment Variables for deployment.

# Server
PORT=8000
NODE_ENV=development

# Database
# Local:      mongodb://localhost:27017/character360
# Production: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<urlencoded-password>@<cluster>.mongodb.net/character360?retryWrites=true&w=majority&appName=Cluster0
DB_NAME=character360

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Client (frontend URL)
# Local:      http://localhost:5173
# Production: https://your-frontend.vercel.app
CLIENT_URL=

# Super Admin Seed (only needed for seeding)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
